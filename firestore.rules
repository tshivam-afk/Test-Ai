rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper conditions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User's custom uploaded Workbooks
    match /users/{userId}/workbooks/{workbookId} {
      allow read, write, delete: if isOwner(userId) && isValidId(userId) && isValidId(workbookId);
    }

    // User's progression state record of each Workbook
    match /users/{userId}/progress/{workbookId} {
      allow read, write, delete: if isOwner(userId) && isValidId(userId) && isValidId(workbookId);
    }

    // User's final submitted Exam analysis history logs
    match /users/{userId}/history/{historyId} {
      allow read, write, delete: if isOwner(userId) && isValidId(userId) && isValidId(historyId);
    }
  }
}

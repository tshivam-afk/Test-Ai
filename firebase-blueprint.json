{
  "entities": {
    "Workbook": {
      "title": "Workbook",
      "description": "Represents custom uploaded NEET practice test workbooks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "questions": { "type": "array" },
        "createdAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "questions", "createdAt", "userId"]
    },
    "WorkbookProgress": {
      "title": "WorkbookProgress",
      "description": "Represents individual progress in a workbook.",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "answers": { "type": "object" },
        "flagged": { "type": "array" },
        "bookmarked": { "type": "array" },
        "userNotes": { "type": "object" },
        "confidences": { "type": "object" },
        "timeSpent": { "type": "number" },
        "completed": { "type": "boolean" },
        "score": { "type": "object" },
        "lastActiveQuestionNumber": { "type": "number" },
        "lastUpdatedAt": { "type": "string" },
        "mode": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["testId", "answers", "flagged", "bookmarked", "userNotes", "timeSpent", "completed", "lastActiveQuestionNumber", "lastUpdatedAt", "userId"]
    },
    "ExamHistory": {
      "title": "ExamHistory",
      "description": "Logs final submitted exam result attempts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "testId": { "type": "string" },
        "testTitle": { "type": "string" },
        "dateTime": { "type": "string" },
        "timeSpent": { "type": "number" },
        "score": { "type": "object" },
        "answers": { "type": "object" },
        "confidences": { "type": "object" },
        "questions": { "type": "array" },
        "userId": { "type": "string" }
      },
      "required": ["id", "testId", "testTitle", "dateTime", "timeSpent", "score", "answers", "questions", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}/workbooks/{workbookId}": {
      "schema": "Workbook",
      "description": "User custom workbooks."
    },
    "/users/{userId}/progress/{workbookId}": {
      "schema": "WorkbookProgress",
      "description": "User test progress details."
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "ExamHistory",
      "description": "User historic test submission analysis."
    }
  }
}
